---
---

<section id="download" class="grain starfield relative overflow-hidden py-32 md:py-44">
  <!-- Deep space nebula background -->
  <div class="pointer-events-none absolute inset-0">
    <div class="animate-drift absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[600px] w-[800px] rounded-full bg-(--color-accent)/8 blur-[150px]"></div>
    <div class="animate-drift absolute top-0 right-0 h-[300px] w-[400px] rounded-full bg-(--color-warm)/4 blur-[120px]" style="animation-delay: -5s;"></div>
    <div class="animate-drift absolute bottom-0 left-0 h-[300px] w-[400px] rounded-full bg-(--color-cool)/4 blur-[120px]" style="animation-delay: -12s;"></div>
  </div>

  <!-- Twinkling stars for download CTA -->
  <div class="pointer-events-none absolute inset-0 z-[1]">
    <div class="animate-twinkle absolute top-[10%] left-[15%] h-1 w-1 rounded-full bg-(--color-star)" style="animation-delay: 0.2s;"></div>
    <div class="animate-twinkle absolute top-[20%] right-[20%] h-1.5 w-1.5 rounded-full bg-(--color-star)" style="animation-delay: 1.5s;"></div>
    <div class="animate-twinkle absolute top-[50%] left-[5%] h-0.5 w-0.5 rounded-full bg-(--color-star-dim)" style="animation-delay: 0.8s;"></div>
    <div class="animate-twinkle absolute bottom-[15%] right-[12%] h-1 w-1 rounded-full bg-(--color-star)" style="animation-delay: 2.3s;"></div>
    <div class="animate-twinkle absolute top-[35%] right-[5%] h-0.5 w-0.5 rounded-full bg-(--color-star-dim)" style="animation-delay: 1.1s;"></div>
    <div class="animate-twinkle absolute bottom-[30%] left-[25%] h-0.5 w-0.5 rounded-full bg-(--color-star)" style="animation-delay: 2.7s;"></div>
  </div>

  <!-- Subtle top border -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 h-px w-2/3 bg-gradient-to-r from-transparent via-(--color-border) to-transparent"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8">
    <div class="reveal text-center">
      <!-- Large, cinematic headline -->
      <h2 class="font-display text-[clamp(3rem,8vw,6rem)] leading-[0.9] tracking-tight text-(--color-text) mb-8">
        Start building<br />
        what <em class="text-(--color-accent)">matters</em>
      </h2>

      <p class="mx-auto mb-12 max-w-lg text-[17px] leading-relaxed text-(--color-text-secondary)">
        Download North Star and turn your next customer conversation into
        actionable product intelligence.
      </p>

      <!-- Download button — large, prominent -->
      <div class="reveal reveal-delay-1">
        <a
          href="#"
          class="group relative inline-flex items-center gap-3 overflow-hidden rounded-full bg-(--color-accent-solid) px-10 py-5 text-lg font-medium text-white transition-all duration-500 hover:bg-(--color-accent-solid-hover) hover:shadow-glow hover:scale-[1.02]"
        >
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"></path>
          </svg>
          <span class="relative z-10">Download for macOS</span>
          <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent translate-x-[-200%] transition-transform duration-1000 group-hover:translate-x-[200%]"></div>
        </a>
      </div>

      <!-- System requirements -->
      <p class="reveal reveal-delay-2 mt-6 text-[13px] text-(--color-text-tertiary)">
        Requires macOS 14 (Sonoma) or later &middot; Apple Silicon recommended
      </p>
    </div>
  </div>
</section>
