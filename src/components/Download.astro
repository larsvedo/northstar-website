---
---

<section id="download" class="grain starfield relative overflow-hidden py-32 md:py-44">
  <!-- Deep space nebula background -->
  <div class="pointer-events-none absolute inset-0">
    <div class="animate-drift absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[600px] w-[800px] rounded-full bg-(--color-accent)/8 blur-[150px]"></div>
    <div class="animate-drift absolute top-0 right-0 h-[300px] w-[400px] rounded-full bg-(--color-warm)/4 blur-[120px]" style="animation-delay: -5s;"></div>
    <div class="animate-drift absolute bottom-0 left-0 h-[300px] w-[400px] rounded-full bg-(--color-cool)/4 blur-[120px]" style="animation-delay: -12s;"></div>
  </div>

  <!-- Twinkling stars for download CTA -->
  <div class="pointer-events-none absolute inset-0 z-[1]">
    <div class="animate-twinkle absolute top-[10%] left-[15%] h-1 w-1 rounded-full bg-(--color-star)" style="animation-delay: 0.2s;"></div>
    <div class="animate-twinkle absolute top-[20%] right-[20%] h-1.5 w-1.5 rounded-full bg-(--color-star)" style="animation-delay: 1.5s;"></div>
    <div class="animate-twinkle absolute top-[50%] left-[5%] h-0.5 w-0.5 rounded-full bg-(--color-star-dim)" style="animation-delay: 0.8s;"></div>
    <div class="animate-twinkle absolute bottom-[15%] right-[12%] h-1 w-1 rounded-full bg-(--color-star)" style="animation-delay: 2.3s;"></div>
    <div class="animate-twinkle absolute top-[35%] right-[5%] h-0.5 w-0.5 rounded-full bg-(--color-star-dim)" style="animation-delay: 1.1s;"></div>
    <div class="animate-twinkle absolute bottom-[30%] left-[25%] h-0.5 w-0.5 rounded-full bg-(--color-star)" style="animation-delay: 2.7s;"></div>
  </div>

  <!-- Subtle top border -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 h-px w-2/3 bg-gradient-to-r from-transparent via-(--color-border) to-transparent"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8">
    <div class="reveal text-center">
      <!-- Large, cinematic headline -->
      <h2 class="font-display text-[clamp(3rem,8vw,6rem)] leading-[0.9] tracking-tight text-(--color-text) mb-8">
        Start building<br />
        what <em class="text-(--color-accent)">matters</em>
      </h2>

      <p class="mx-auto mb-12 max-w-lg text-[17px] leading-relaxed text-(--color-text-secondary)">
        Download North Star and start turning your conversations and thoughts
        into context your whole team can use.
      </p>

      <!-- Waitlist signup -->
      <div class="reveal reveal-delay-1">
        <form id="waitlist-form" class="mx-auto flex max-w-md flex-col gap-3 sm:flex-row">
          <input
            type="email"
            id="waitlist-email"
            required
            placeholder="Enter your email"
            class="flex-1 rounded-full border border-(--color-border) bg-(--color-surface) px-5 py-3.5 text-sm text-(--color-text) placeholder:text-(--color-text-tertiary) outline-none transition-all duration-300 focus:border-(--color-accent) focus:ring-1 focus:ring-(--color-accent)"
          />
          <button
            type="submit"
            class="group relative inline-flex items-center justify-center gap-2.5 overflow-hidden rounded-full bg-(--color-accent-solid) px-7 py-3.5 text-sm font-medium text-white transition-all duration-300 hover:bg-(--color-accent-solid-hover) hover:shadow-glow hover:scale-[1.02] disabled:opacity-60 disabled:pointer-events-none"
          >
            <span id="waitlist-btn-text">Join the Waitlist</span>
            <svg id="waitlist-spinner" class="hidden h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent translate-x-[-200%] transition-transform duration-700 group-hover:translate-x-[200%]"></div>
          </button>
        </form>
        <p id="waitlist-message" class="mt-3 text-sm hidden"></p>
      </div>

      <!-- System requirements -->
      <p class="reveal reveal-delay-2 mt-6 text-[13px] text-(--color-text-tertiary)">
        macOS 14+ &middot; Apple Silicon recommended &middot; Coming soon
      </p>
    </div>
  </div>
</section>

<script>
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const emailInput = document.getElementById('waitlist-email') as HTMLInputElement;
  const btnText = document.getElementById('waitlist-btn-text')!;
  const spinner = document.getElementById('waitlist-spinner')!;
  const message = document.getElementById('waitlist-message')!;

  function showMessage(text: string, isError: boolean) {
    message.textContent = text;
    message.classList.remove('hidden', 'text-(--color-cool)', 'text-(--color-error)');
    message.classList.add(isError ? 'text-(--color-error)' : 'text-(--color-cool)');
  }

  function setLoading(loading: boolean) {
    const btn = form.querySelector('button')!;
    btn.disabled = loading;
    btnText.textContent = loading ? 'Joining...' : 'Join the Waitlist';
    spinner.classList.toggle('hidden', !loading);
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) return;

    setLoading(true);
    message.classList.add('hidden');

    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/waitlist`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify({ email }),
      });

      if (res.ok) {
        showMessage("You're on the list! We'll be in touch.", false);
        emailInput.value = '';
      } else if (res.status === 409) {
        showMessage("You're already on the list!", false);
      } else {
        showMessage('Something went wrong. Please try again.', true);
      }
    } catch {
      showMessage('Something went wrong. Please try again.', true);
    } finally {
      setLoading(false);
    }
  });
</script>
