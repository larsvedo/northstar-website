<section id="download" class="border-t border-(--color-border) bg-(--color-surface) py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <!-- Star icon -->
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-(--color-accent)/10">
        <svg class="h-8 w-8 text-(--color-accent)" viewBox="0 0 32 32" fill="currentColor">
          <path d="M16 2 L18.5 12 L28 12 L20 18.5 L23 28 L16 22 L9 28 L12 18.5 L4 12 L13.5 12 Z"></path>
        </svg>
      </div>

      <h2 class="mb-4 text-3xl font-bold tracking-tight text-(--color-text) md:text-4xl">
        Start building what matters
      </h2>
      <p class="mb-8 text-lg text-(--color-text-secondary)">
        Download North Star and turn your next customer conversation into
        actionable product intelligence.
      </p>

      <!-- Download button -->
      <a
        href="#"
        class="inline-flex items-center gap-2 rounded-xl bg-(--color-accent) px-8 py-4 text-lg font-medium text-white shadow-lg shadow-(--color-accent)/25 transition-all hover:bg-(--color-accent-hover) hover:shadow-xl hover:shadow-(--color-accent)/30"
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
          ></path>
        </svg>
        Download for macOS
      </a>

      <!-- System requirements -->
      <p class="mt-4 text-sm text-(--color-text-secondary)">
        Requires macOS 14 (Sonoma) or later. Apple Silicon recommended.
      </p>
    </div>
  </div>
</section>
