---
const steps = [
  {
    number: "1",
    title: "Record",
    description:
      "Start a recording during any call. North Star captures microphone and system audio automatically — works with Zoom, Meet, Teams, or any conferencing tool.",
    icon: `<circle cx="12" cy="12" r="10" /><polygon points="10 8 16 12 10 16 10 8" />`,
  },
  {
    number: "2",
    title: "Transcribe",
    description:
      "WhisperKit transcribes on-device using Apple Neural Engine. No cloud uploads, no per-minute costs. Your conversations stay private on your Mac.",
    icon: `<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" /><polyline points="14 2 14 8 20 8" /><line x1="16" x2="8" y1="13" y2="13" /><line x1="16" x2="8" y1="17" y2="17" /><line x1="10" x2="8" y1="9" y2="9" />`,
  },
  {
    number: "3",
    title: "Analyze",
    description:
      "AI extracts feature requests, sentiment, blockers, and action items. Your conversations become structured product intelligence — searchable, trackable, actionable.",
    icon: `<path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /><path d="M18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25z" />`,
  },
];
---

<section id="how-it-works" class="border-t border-(--color-border) py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Section header -->
    <div class="mx-auto mb-16 max-w-2xl text-center">
      <p class="mb-4 text-sm font-medium tracking-wide text-(--color-accent) uppercase">
        How It Works
      </p>
      <h2 class="mb-4 text-3xl font-bold tracking-tight text-(--color-text) md:text-4xl">
        Three steps. Zero overhead.
      </h2>
      <p class="text-lg text-(--color-text-secondary)">
        North Star works in the background while you focus on the conversation.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid gap-12 md:grid-cols-3 md:gap-8">
      {
        steps.map((step, i) => (
          <div class="relative text-center">
            {/* Connector line (hidden on mobile, shown between items on desktop) */}
            {i < steps.length - 1 && (
              <div class="absolute top-10 left-[calc(50%+48px)] hidden h-px w-[calc(100%-96px)] bg-(--color-border) md:block" />
            )}

            {/* Step number badge */}
            <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-2xl bg-(--color-accent)/10">
              <svg
                class="h-8 w-8 text-(--color-accent)"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                set:html={step.icon}
              />
            </div>

            {/* Number */}
            <div class="mb-2 text-sm font-medium text-(--color-accent)">
              Step {step.number}
            </div>

            <h3 class="mb-3 text-xl font-semibold text-(--color-text)">
              {step.title}
            </h3>
            <p class="mx-auto max-w-sm text-sm leading-relaxed text-(--color-text-secondary)">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
