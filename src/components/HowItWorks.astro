---
const steps = [
  {
    number: "01",
    title: "Capture",
    description:
      "Record any conversation — customer calls, engineering syncs, support debriefs, team standups. One click, both sides captured, works with Zoom, Meet, Teams, or any conferencing tool.",
    color: "--color-accent",
  },
  {
    number: "02",
    title: "Extract",
    description:
      "On-device transcription via WhisperKit, then AI extracts structured insights — feature requests, pain points, engineering decisions, blockers, action items. Not summaries. Structured product intelligence.",
    color: "--color-cool",
  },
  {
    number: "03",
    title: "Compound",
    description:
      "Every insight accumulates into a growing knowledge base. Patterns emerge across conversations that no single meeting reveals. A customer pain point from Tuesday connects to the engineering decision from Thursday.",
    color: "--color-warm",
  },
];
---

<section id="how-it-works" class="starfield relative py-28 md:py-40">
  <!-- Subtle top border -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 h-px w-2/3 bg-gradient-to-r from-transparent via-(--color-border) to-transparent"></div>

  <!-- Background nebula glow -->
  <div class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[500px] w-[600px] rounded-full bg-(--color-accent)/5 blur-[150px] animate-drift"></div>

  <!-- Twinkling stars -->
  <div class="pointer-events-none absolute inset-0">
    <div class="animate-twinkle absolute top-[10%] left-[20%] h-0.5 w-0.5 rounded-full bg-(--color-star)" style="animation-delay: 0.3s;"></div>
    <div class="animate-twinkle absolute top-[30%] right-[10%] h-1 w-1 rounded-full bg-(--color-star)" style="animation-delay: 1.8s;"></div>
    <div class="animate-twinkle absolute bottom-[25%] left-[8%] h-0.5 w-0.5 rounded-full bg-(--color-star-dim)" style="animation-delay: 2.5s;"></div>
    <div class="animate-twinkle absolute top-[65%] right-[25%] h-0.5 w-0.5 rounded-full bg-(--color-star-dim)" style="animation-delay: 0.9s;"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="reveal mb-24 max-w-xl">
      <span class="inline-flex items-center gap-2 text-[13px] tracking-widest text-(--color-text-tertiary) uppercase mb-6 block">
        <span class="inline-block h-px w-8 bg-(--color-cool)"></span>
        How it works
      </span>
      <h2 class="font-display text-[clamp(2.5rem,5vw,3.5rem)] leading-[0.95] tracking-tight text-(--color-text)">
        Three steps.<br /><em class="text-(--color-cool)">Zero overhead.</em>
      </h2>
    </div>

    <!-- Steps — large numbered layout -->
    <div class="space-y-0">
      {
        steps.map((step, i) => (
          <div class="reveal group" style={`transition-delay: ${i * 0.15}s`}>
            <div class="grid items-start gap-8 border-t border-(--color-border) py-12 md:grid-cols-12 md:py-16">
              <!-- Number -->
              <div class="md:col-span-2">
                <span class="font-display text-5xl md:text-6xl" style={`color: var(${step.color}); opacity: 0.3`}>
                  {step.number}
                </span>
              </div>

              <!-- Title -->
              <div class="md:col-span-3">
                <h3 class="text-2xl font-medium text-(--color-text) md:text-3xl">
                  {step.title}
                </h3>
              </div>

              <!-- Description -->
              <div class="md:col-span-6 md:col-start-7">
                <p class="text-[17px] leading-[1.7] text-(--color-text-secondary)">
                  {step.description}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
