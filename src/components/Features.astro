---
const features = [
  {
    title: "Every Conversation",
    description:
      "Customer calls, engineering syncs, support debriefs, team standups — all recorded. Both sides of any call. Works with Zoom, Meet, Teams, and any app that plays audio.",
    detail: "Not just customer calls.",
    color: "accent",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />`,
  },
  {
    title: "On-Device Transcription",
    description:
      "WhisperKit transcribes locally using Apple Neural Engine. Your audio never leaves your Mac. No cloud, no cost per minute, no privacy concerns. Frictionless enough that every conversation makes it into the system.",
    detail: "Private. Fast. On your Mac.",
    color: "cool",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />`,
  },
  {
    title: "Compounding Intelligence",
    description:
      "Every conversation becomes a data point in a growing knowledge base. AI extracts feature requests, pain points, decisions, and blockers. Your 50th insight reveals patterns that were invisible in the first 10.",
    detail: "Gets smarter over time.",
    color: "accent",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />`,
  },
  {
    title: "API & MCP Server",
    description:
      "Structured insights flow to AI coding assistants, project trackers, and team tools. When an engineer is building a feature, they get real customer context. Your product intelligence, consumable by both humans and AI.",
    detail: "Intelligence that flows.",
    color: "warm",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />`,
  },
  {
    title: "iOS Companion",
    description:
      "Record conversations on the go and review insights anywhere. Automatic sync keeps everything in one knowledge base — whether you're at your desk or grabbing coffee with a customer.",
    detail: "No conversation left behind.",
    color: "cool",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />`,
  },
  {
    title: "Built-in Productivity",
    description:
      "System-wide dictation, screenshot annotation, and clipboard manager with global hotkeys. The tools that make North Star your daily driver — always open, always accumulating.",
    detail: "Always open. Always useful.",
    color: "warm",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />`,
  },
];

function getColorVar(color: string) {
  return color === "warm" ? "--color-warm" : color === "cool" ? "--color-cool" : "--color-accent";
}
function getColorMuted(color: string) {
  return color === "warm" ? "--color-warm-muted" : color === "cool" ? "--color-cool-muted" : "--color-accent-muted";
}
---

<section id="features" class="grain relative py-28 md:py-40">
  <!-- Subtle top border -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 h-px w-2/3 bg-gradient-to-r from-transparent via-(--color-border) to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header — left aligned -->
    <div class="reveal mb-20 max-w-xl">
      <span class="inline-flex items-center gap-2 text-[13px] tracking-widest text-(--color-text-tertiary) uppercase mb-6 block">
        <span class="inline-block h-px w-8 bg-(--color-accent)"></span>
        Features
      </span>
      <h2 class="font-display text-[clamp(2.5rem,5vw,3.5rem)] leading-[0.95] tracking-tight text-(--color-text) mb-5">
        Everything you need to <em class="text-(--color-accent)">keep up</em>
      </h2>
      <p class="text-[17px] leading-relaxed text-(--color-text-secondary)">
        From capture to intelligence. Every conversation feeds the same system.
      </p>
    </div>

    <!-- Feature items — stacked list layout -->
    <div class="space-y-3">
      {
        features.map((feature, i) => (
          <div
            class="reveal group card-gradient rounded-2xl p-6 md:p-8 transition-all duration-500 hover:bg-(--color-surface-alt)"
            style={`transition-delay: ${i * 0.05}s`}
          >
            <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
              <!-- Left: icon + title -->
              <div class="flex items-center gap-5">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl" style={`background: var(${getColorMuted(feature.color)})`}>
                  <svg
                    class="h-5 w-5"
                    style={`color: var(${getColorVar(feature.color)})`}
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    set:html={feature.icon}
                  />
                </div>
                <div>
                  <h3 class="text-base font-medium text-(--color-text) md:text-lg">
                    {feature.title}
                  </h3>
                  <p class="text-sm text-(--color-text-tertiary) md:hidden mt-1">
                    {feature.description}
                  </p>
                </div>
              </div>

              <!-- Center: description (desktop only) -->
              <p class="hidden max-w-md text-sm leading-relaxed text-(--color-text-secondary) md:block">
                {feature.description}
              </p>

              <!-- Right: short detail -->
              <span class="hidden text-right text-sm font-medium tracking-wide md:block" style={`color: var(${getColorVar(feature.color)})`}>
                {feature.detail}
              </span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
