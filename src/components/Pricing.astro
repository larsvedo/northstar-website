---
const tiers = [
  {
    name: "Solo",
    price: "Free",
    period: "",
    description: "For individual use. Get value from day one.",
    features: [
      "Record and transcribe calls",
      "AI-powered insight extraction",
      "Local storage on your Mac",
      "Dictation with global hotkey",
      "Screenshots and annotation",
      "Clipboard history and snippets",
    ],
    cta: "Download Free",
    highlighted: false,
  },
  {
    name: "Pro",
    price: "$19",
    period: "/mo",
    description: "For power users who want deeper analysis.",
    features: [
      "Everything in Solo",
      "Higher volume limits",
      "Trend detection across conversations",
      "Sentiment tracking over time",
      "Priority transcription",
      "Export and integrations",
    ],
    cta: "Get Pro",
    highlighted: true,
  },
  {
    name: "Team",
    price: "$29",
    period: "/user/mo",
    description: "For teams that share product context.",
    features: [
      "Everything in Pro",
      "Shared workspaces",
      "Aggregate insights across teammates",
      "Customer-level conversation views",
      "Team dashboards and reporting",
      "Cloud sync",
    ],
    cta: "Get Team",
    highlighted: false,
  },
  {
    name: "Business",
    price: "Custom",
    period: "",
    description: "For organizations that need control.",
    features: [
      "Everything in Team",
      "SSO and admin controls",
      "API access",
      "Custom integrations",
      "Dedicated support",
      "SLA guarantee",
    ],
    cta: "Contact Us",
    highlighted: false,
  },
];
---

<section id="pricing" class="relative py-28 md:py-40">
  <!-- Subtle top border -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 h-px w-2/3 bg-gradient-to-r from-transparent via-(--color-border) to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="reveal mb-20 max-w-xl">
      <span class="inline-flex items-center gap-2 text-[13px] tracking-widest text-(--color-text-tertiary) uppercase mb-6 block">
        <span class="inline-block h-px w-8 bg-(--color-accent)"></span>
        Pricing
      </span>
      <h2 class="font-display text-[clamp(2.5rem,5vw,3.5rem)] leading-[0.95] tracking-tight text-(--color-text) mb-5">
        Free to start.<br /><em class="text-(--color-accent)">Scales with you.</em>
      </h2>
      <p class="text-[17px] leading-relaxed text-(--color-text-secondary)">
        The free tier is genuinely useful. No artificial restrictions designed to frustrate you into upgrading.
      </p>
    </div>

    <!-- Pricing grid -->
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {
        tiers.map((tier, i) => (
          <div
            class:list={[
              "reveal relative flex flex-col rounded-2xl p-6 transition-all duration-500",
              tier.highlighted
                ? "card-gradient shadow-glow"
                : "card-gradient",
            ]}
            style={`transition-delay: ${i * 0.1}s`}
          >
            {tier.highlighted && (
              <div class="absolute -top-3 left-6 rounded-full bg-(--color-accent-solid) px-3 py-1 text-[10px] font-medium tracking-wider text-white uppercase">
                Popular
              </div>
            )}

            <div class="mb-8">
              <h3 class="mb-1 text-sm font-medium tracking-wide text-(--color-text-secondary) uppercase">
                {tier.name}
              </h3>
              <div class="mt-3 flex items-baseline gap-1">
                <span class="text-4xl font-light tracking-tight text-(--color-text)">
                  {tier.price}
                </span>
                {tier.period && (
                  <span class="text-sm text-(--color-text-tertiary)">
                    {tier.period}
                  </span>
                )}
              </div>
              <p class="mt-3 text-[13px] text-(--color-text-tertiary)">
                {tier.description}
              </p>
            </div>

            <ul class="mb-8 flex-1 space-y-3">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-2.5 text-[13px] text-(--color-text-secondary)">
                  <svg
                    class="mt-0.5 h-3.5 w-3.5 shrink-0 text-(--color-accent)"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M4.5 12.75l6 6 9-13.5"
                    />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <a
              href="#download"
              class:list={[
                "group relative overflow-hidden rounded-full px-5 py-2.5 text-center text-[13px] font-medium transition-all duration-300",
                tier.highlighted
                  ? "bg-(--color-accent-solid) text-white hover:bg-(--color-accent-solid-hover) hover:shadow-glow"
                  : "border border-(--color-border) text-(--color-text) hover:border-(--color-border-accent) hover:text-(--color-accent)",
              ]}
            >
              <span class="relative z-10">{tier.cta}</span>
              {tier.highlighted && (
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent translate-x-[-200%] transition-transform duration-700 group-hover:translate-x-[200%]"></div>
              )}
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
