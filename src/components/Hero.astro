---
---

<section class="grain starfield relative min-h-screen overflow-hidden pt-24 pb-0 md:pt-32">
  <!-- Background: deep space nebula glows -->
  <div class="pointer-events-none absolute inset-0">
    <div class="animate-drift absolute top-[-20%] left-1/2 -translate-x-1/2 h-[600px] w-[800px] rounded-full bg-(--color-accent)/6 blur-[150px]"></div>
    <div class="animate-drift absolute bottom-0 left-0 h-[400px] w-[400px] rounded-full bg-(--color-warm)/4 blur-[120px]" style="animation-delay: -7s;"></div>
    <div class="animate-drift absolute top-1/4 right-0 h-[300px] w-[300px] rounded-full bg-(--color-cool)/4 blur-[120px]" style="animation-delay: -14s;"></div>
  </div>

  <!-- Twinkling stars -->
  <div class="pointer-events-none absolute inset-0 z-[1]">
    <div class="animate-twinkle absolute top-[8%] left-[12%] h-1 w-1 rounded-full bg-(--color-star)" style="animation-delay: 0s;"></div>
    <div class="animate-twinkle absolute top-[15%] left-[68%] h-0.5 w-0.5 rounded-full bg-(--color-star-dim)" style="animation-delay: 0.8s;"></div>
    <div class="animate-twinkle absolute top-[25%] left-[85%] h-1.5 w-1.5 rounded-full bg-(--color-star)" style="animation-delay: 1.6s;"></div>
    <div class="animate-twinkle absolute top-[40%] left-[5%] h-0.5 w-0.5 rounded-full bg-(--color-star-dim)" style="animation-delay: 2.2s;"></div>
    <div class="animate-twinkle absolute top-[55%] left-[92%] h-1 w-1 rounded-full bg-(--color-star)" style="animation-delay: 0.4s;"></div>
    <div class="animate-twinkle absolute top-[70%] left-[30%] h-0.5 w-0.5 rounded-full bg-(--color-star-dim)" style="animation-delay: 1.2s;"></div>
    <div class="animate-twinkle absolute top-[12%] left-[45%] h-0.5 w-0.5 rounded-full bg-(--color-star)" style="animation-delay: 2.8s;"></div>
    <div class="animate-twinkle absolute top-[80%] left-[75%] h-1 w-1 rounded-full bg-(--color-star-dim)" style="animation-delay: 1.9s;"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Asymmetric layout: text left, visual weight right -->
    <div class="grid min-h-[70vh] items-center gap-12 lg:grid-cols-12 lg:gap-8">

      <!-- Text block — left aligned, not centered -->
      <div class="lg:col-span-6 xl:col-span-5">
        <!-- Micro-label -->
        <div class="reveal mb-8">
          <span class="inline-flex items-center gap-2 text-[13px] tracking-widest text-(--color-text-tertiary) uppercase">
            <span class="inline-block h-px w-8 bg-(--color-accent)"></span>
            Product Management
          </span>
        </div>

        <!-- Headline: large, editorial, serif -->
        <h1 class="reveal reveal-delay-1 mb-8">
          <span class="font-display block text-[clamp(3rem,7vw,5.5rem)] leading-[0.92] tracking-tight text-(--color-text)">
            Build what
          </span>
          <span class="font-display block text-[clamp(3rem,7vw,5.5rem)] leading-[0.92] tracking-tight">
            <em class="text-(--color-accent)">matters</em>
          </span>
        </h1>

        <!-- Subhead -->
        <p class="reveal reveal-delay-2 mb-10 max-w-md text-base leading-relaxed text-(--color-text-secondary) md:text-[17px]">
          A native macOS app that records customer conversations, transcribes them locally, and extracts AI-powered product insights. Sign up for early access.
        </p>

        <!-- Email signup -->
        <form id="hero-signup-form" class="reveal reveal-delay-3 flex flex-col gap-3 sm:flex-row sm:items-center">
          <div class="relative flex-1 max-w-sm">
            <input
              type="email"
              name="email"
              required
              placeholder="you@email.com"
              class="w-full rounded-full border border-(--color-border) bg-(--color-surface) px-5 py-3.5 text-sm text-(--color-text) placeholder:text-(--color-text-tertiary) outline-none transition-all duration-300 focus:border-(--color-accent) focus:ring-1 focus:ring-(--color-accent)"
            />
          </div>
          <button
            type="submit"
            class="group relative inline-flex items-center justify-center gap-2.5 overflow-hidden rounded-full bg-(--color-accent-solid) px-7 py-3.5 text-sm font-medium text-white transition-all duration-300 hover:bg-(--color-accent-solid-hover) hover:shadow-glow"
          >
            <span class="relative z-10">Join the Waitlist</span>
            <svg class="relative z-10 h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
            </svg>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent translate-x-[-200%] transition-transform duration-700 group-hover:translate-x-[200%]"></div>
          </button>
        </form>
        <!-- Success message (hidden by default) -->
        <div id="hero-signup-success" class="reveal reveal-delay-3 hidden">
          <div class="inline-flex items-center gap-2 rounded-full bg-(--color-cool-muted) px-5 py-3 text-sm text-(--color-cool)">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            You're on the list! We'll be in touch soon.
          </div>
        </div>

        <!-- Trust line -->
        <p class="reveal reveal-delay-4 mt-10 text-[13px] text-(--color-text-tertiary)">
          Coming soon for macOS &middot; Be the first to know &middot; No spam, ever
        </p>
      </div>

      <!-- App showcase — right side, bleeding off edge -->
      <div class="reveal reveal-delay-2 relative lg:col-span-6 xl:col-span-7">
        <div class="relative lg:ml-8 xl:ml-16 lg:-mr-24 xl:-mr-32">
          <!-- Main app window -->
          <div class="animate-float shadow-premium relative overflow-hidden rounded-2xl border border-(--color-border)" style="animation-delay: 0s;">
            <!-- Title bar -->
            <div class="flex items-center gap-2 border-b border-(--color-border) bg-(--color-surface) px-4 py-3">
              <div class="h-2.5 w-2.5 rounded-full bg-[#FF5F57]"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-[#FEBC2E]"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-[#28C840]"></div>
              <span class="ml-3 text-[11px] tracking-wide text-(--color-text-tertiary)">North Star</span>
            </div>
            <!-- App content mockup -->
            <div class="bg-(--color-surface-alt) p-6 aspect-[16/10]">
              <!-- Sidebar + content simulation -->
              <div class="flex h-full gap-4">
                <!-- Sidebar -->
                <div class="hidden w-44 shrink-0 rounded-xl bg-(--color-surface) p-3 md:block">
                  <div class="mb-4 flex items-center gap-2">
                    <svg class="h-4 w-4 text-(--color-accent)" viewBox="0 0 32 32" fill="currentColor">
                      <path d="M16 2 L18.5 12 L28 12 L20 18.5 L23 28 L16 22 L9 28 L12 18.5 L4 12 L13.5 12 Z"></path>
                    </svg>
                    <span class="text-[11px] font-medium text-(--color-text)">Dashboard</span>
                  </div>
                  <div class="space-y-1.5">
                    <div class="rounded-lg bg-(--color-accent)/10 px-2.5 py-1.5 text-[10px] text-(--color-accent)">Recordings</div>
                    <div class="rounded-lg px-2.5 py-1.5 text-[10px] text-(--color-text-tertiary)">Insights</div>
                    <div class="rounded-lg px-2.5 py-1.5 text-[10px] text-(--color-text-tertiary)">Feedback</div>
                    <div class="rounded-lg px-2.5 py-1.5 text-[10px] text-(--color-text-tertiary)">Dictation</div>
                    <div class="rounded-lg px-2.5 py-1.5 text-[10px] text-(--color-text-tertiary)">Screenshots & Recording</div>
                  </div>
                </div>
                <!-- Content area -->
                <div class="flex-1 rounded-xl bg-(--color-surface) p-4">
                  <div class="mb-3 flex items-center justify-between">
                    <span class="text-[11px] font-medium text-(--color-text)">Customer Interview — Acme Corp</span>
                    <span class="rounded-full bg-(--color-cool-muted) px-2 py-0.5 text-[9px] text-(--color-cool)">Transcribed</span>
                  </div>
                  <div class="space-y-2">
                    <div class="rounded-lg bg-(--color-surface-alt) p-2.5">
                      <p class="text-[10px] leading-relaxed text-(--color-text-secondary)">"The onboarding flow is confusing. We lost three team members in the first week because they couldn't figure out..."</p>
                    </div>
                    <div class="flex gap-2">
                      <span class="rounded-full bg-(--color-accent-muted) px-2 py-0.5 text-[9px] text-(--color-accent)">Feature Request</span>
                      <span class="rounded-full bg-(--color-warm-muted) px-2 py-0.5 text-[9px] text-(--color-warm)">Churn Signal</span>
                    </div>
                    <div class="rounded-lg bg-(--color-surface-alt) p-2.5">
                      <p class="text-[10px] leading-relaxed text-(--color-text-secondary)">"What we really need is a way to see all feedback in one place, not scattered across Slack and email..."</p>
                    </div>
                    <div class="flex gap-2">
                      <span class="rounded-full bg-(--color-accent-muted) px-2 py-0.5 text-[9px] text-(--color-accent)">Feature Request</span>
                      <span class="rounded-full bg-(--color-cool-muted) px-2 py-0.5 text-[9px] text-(--color-cool)">Pain Point</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating insight card — overlapping, offset -->
          <div class="animate-float absolute -bottom-6 -left-4 z-20 hidden md:block" style="animation-delay: 1.5s;">
            <div class="card-gradient shadow-premium rounded-2xl p-4 w-56">
              <div class="flex items-center gap-2 mb-2">
                <div class="flex h-6 w-6 items-center justify-center rounded-lg bg-(--color-warm-muted)">
                  <svg class="h-3 w-3 text-(--color-warm)" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
                  </svg>
                </div>
                <span class="text-[11px] font-medium text-(--color-text)">Trending Topic</span>
              </div>
              <p class="text-[10px] text-(--color-text-secondary)">Onboarding mentioned by <span class="text-(--color-warm)">4 customers</span> this week</p>
            </div>
          </div>

          <!-- Floating action item — top right, slightly tilted -->
          <div class="animate-float absolute -top-4 right-8 z-20 hidden lg:block" style="animation-delay: 3s;">
            <div class="card-gradient shadow-premium rounded-xl p-3 w-48 rotate-2">
              <div class="flex items-center gap-2">
                <div class="flex h-5 w-5 items-center justify-center rounded-md bg-(--color-cool-muted)">
                  <svg class="h-3 w-3 text-(--color-cool)" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                </div>
                <span class="text-[10px] text-(--color-text-secondary)">Action: Redesign onboarding</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom fade to next section -->
  <div class="pointer-events-none absolute right-0 bottom-0 left-0 h-32 bg-gradient-to-t from-(--color-bg) to-transparent"></div>
</section>

<script is:inline>
  (function () {
    function setupSignupForm(formId, successId) {
      var form = document.getElementById(formId);
      var success = document.getElementById(successId);
      if (!form || !success) return;

      form.addEventListener("submit", function (e) {
        e.preventDefault();
        var email = form.querySelector('input[name="email"]').value;
        if (!email) return;

        // Store signup locally (replace with real API endpoint when ready)
        var signups = JSON.parse(localStorage.getItem("northstar_signups") || "[]");
        if (signups.indexOf(email) === -1) {
          signups.push(email);
          localStorage.setItem("northstar_signups", JSON.stringify(signups));
        }

        form.classList.add("hidden");
        success.classList.remove("hidden");
      });
    }

    setupSignupForm("hero-signup-form", "hero-signup-success");
    setupSignupForm("early-access-form", "early-access-success");
  })();
</script>
