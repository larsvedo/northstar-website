---
---

<section class="relative overflow-hidden pt-32 pb-20 md:pt-40 md:pb-28">
  <!-- Subtle gradient background -->
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-b from-(--color-accent)/5 to-transparent"
  ></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <!-- Badge -->
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-(--color-border) bg-(--color-surface) px-4 py-1.5 text-sm text-(--color-text-secondary)">
        <svg class="h-4 w-4 text-(--color-accent)" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        Free for individuals. No account required.
      </div>

      <!-- Headline -->
      <h1
        class="mb-6 text-4xl font-bold tracking-tight text-(--color-text) sm:text-5xl md:text-6xl"
      >
        Build What<br />
        <span class="text-(--color-accent)">Matters</span>
      </h1>

      <!-- Subhead -->
      <p class="mx-auto mb-10 max-w-2xl text-lg text-(--color-text-secondary) md:text-xl">
        Record customer conversations. Get AI-powered insights. Stop building
        features nobody asked for.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="#download"
          class="inline-flex items-center gap-2 rounded-xl bg-(--color-accent) px-6 py-3 text-base font-medium text-white shadow-lg shadow-(--color-accent)/25 transition-all hover:bg-(--color-accent-hover) hover:shadow-xl hover:shadow-(--color-accent)/30"
        >
          <!-- Apple logo -->
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
            ></path>
          </svg>
          Download for macOS
        </a>
        <a
          href="#how-it-works"
          class="inline-flex items-center gap-2 rounded-xl border border-(--color-border) bg-(--color-surface) px-6 py-3 text-base font-medium text-(--color-text) transition-colors hover:bg-(--color-surface-alt)"
        >
          See how it works
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Product screenshot placeholder -->
    <div class="mt-16 flex justify-center">
      <div
        class="w-full max-w-4xl overflow-hidden rounded-2xl border border-(--color-border) bg-(--color-surface) shadow-2xl"
      >
        <div class="flex items-center gap-2 border-b border-(--color-border) px-4 py-3">
          <div class="h-3 w-3 rounded-full bg-red-400"></div>
          <div class="h-3 w-3 rounded-full bg-yellow-400"></div>
          <div class="h-3 w-3 rounded-full bg-green-400"></div>
          <span class="ml-2 text-xs text-(--color-text-secondary)">North Star</span>
        </div>
        <div class="flex aspect-video items-center justify-center bg-(--color-surface-alt) p-8">
          <div class="text-center">
            <svg class="mx-auto mb-4 h-16 w-16 text-(--color-accent)/30" viewBox="0 0 32 32" fill="currentColor">
              <path d="M16 2 L18.5 12 L28 12 L20 18.5 L23 28 L16 22 L9 28 L12 18.5 L4 12 L13.5 12 Z"></path>
            </svg>
            <p class="text-sm text-(--color-text-secondary)">Product screenshot — coming in M2</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
