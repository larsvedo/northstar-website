---
const personas = [
  {
    title: "Solo Founders & Indie Hackers",
    description:
      "You're the PM, the engineer, and the support team. Customer conversations happen fast and context switches are constant. North Star gives you a structured memory of every conversation so you stop building based on gut feel and start building based on what customers actually tell you.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />`,
  },
  {
    title: "Product Managers",
    description:
      "Five customer calls a week generates hundreds of data points. Themes get lost in notebooks and spreadsheets. North Star surfaces patterns across conversations — how many customers mention the same pain point, how sentiment shifts after a release, which commitments were made and to whom.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />`,
  },
  {
    title: "Small Teams",
    description:
      "Engineers talk to customers. Designers run usability tests. Everyone has pieces of the picture, but there's no system to assemble them. North Star becomes the shared product compass — aggregate insights across teammates and see the full picture of what customers are saying.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />`,
  },
];
---

<section id="use-cases" class="border-t border-(--color-border) bg-(--color-surface) py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Section header -->
    <div class="mx-auto mb-16 max-w-2xl text-center">
      <p class="mb-4 text-sm font-medium tracking-wide text-(--color-accent) uppercase">
        Built For
      </p>
      <h2 class="mb-4 text-3xl font-bold tracking-tight text-(--color-text) md:text-4xl">
        For people who build products
      </h2>
      <p class="text-lg text-(--color-text-secondary)">
        Whether you're a solo founder or part of a team, North Star helps you
        build what your customers actually need.
      </p>
    </div>

    <!-- Persona cards -->
    <div class="grid gap-8 md:grid-cols-3">
      {
        personas.map((persona) => (
          <div class="rounded-xl border border-(--color-border) bg-(--color-bg) p-8">
            <div class="mb-5 inline-flex rounded-lg bg-(--color-accent)/10 p-2.5">
              <svg
                class="h-6 w-6 text-(--color-accent)"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                set:html={persona.icon}
              />
            </div>
            <h3 class="mb-3 text-lg font-semibold text-(--color-text)">
              {persona.title}
            </h3>
            <p class="text-sm leading-relaxed text-(--color-text-secondary)">
              {persona.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
