---
const personas = [
  {
    title: "Shape",
    subtitle: "What You Build",
    description:
      "Customer pain points, feature requests, and competitive signals flow into one place. Patterns surface across dozens of conversations that no single call reveals. When it's time to write the spec, the context is already there.",
    color: "--color-warm",
    stat: "Discovery to roadmap",
    statDetail: "Patterns you'd otherwise miss",
  },
  {
    title: "Align",
    subtitle: "Your Team",
    description:
      "Every decision links back to the conversation that shaped it. When someone asks \"why are we building this?\", the answer is grounded in real conversations, not someone's memory. Context travels with the work, not just the person who was in the room.",
    color: "--color-accent",
    stat: "Shared context",
    statDetail: "Decisions grounded in real conversations",
  },
  {
    title: "Supercharge",
    subtitle: "Your AI",
    description:
      "Claude, Cursor, and Copilot are only as good as the context you give them. North Star feeds your product knowledge, customer language, and team decisions directly into your AI tools via MCP. Every prompt is grounded in reality, not guesswork.",
    color: "--color-cool",
    stat: "Context for AI",
    statDetail: "Grounded prompts, better output",
  },
];
---

<section id="use-cases" class="grain relative py-28 md:py-40">
  <!-- Subtle top border -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 h-px w-2/3 bg-gradient-to-r from-transparent via-(--color-border) to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="reveal mb-20 max-w-xl">
      <span class="inline-flex items-center gap-2 text-[13px] tracking-widest text-(--color-text-tertiary) uppercase mb-6 block">
        <span class="inline-block h-px w-8 bg-(--color-warm)"></span>
        Where context flows
      </span>
      <h2 class="font-display text-[clamp(2.5rem,5vw,3.5rem)] leading-[0.95] tracking-tight text-(--color-text)">
        From conversations to <em class="text-(--color-warm)">clarity</em>
      </h2>
    </div>

    <!-- Persona cards — offset grid -->
    <div class="grid gap-6 md:grid-cols-3">
      {
        personas.map((persona, i) => (
          <div
            class="reveal card-gradient group rounded-2xl p-8 transition-all duration-500 hover:bg-(--color-surface-alt)"
            style={`transition-delay: ${i * 0.1}s; ${i === 1 ? 'transform: translateY(2rem)' : ''}`}
          >
            <!-- Title -->
            <div class="mb-6">
              <h3 class="text-2xl font-medium text-(--color-text) leading-tight">
                {persona.title}
              </h3>
              <h3 class="text-2xl font-medium leading-tight" style={`color: var(${persona.color})`}>
                {persona.subtitle}
              </h3>
            </div>

            <!-- Description -->
            <p class="mb-8 text-sm leading-relaxed text-(--color-text-secondary)">
              {persona.description}
            </p>

            <!-- Stat line -->
            <div class="border-t border-(--color-border) pt-5">
              <p class="text-xs font-medium tracking-wide uppercase" style={`color: var(${persona.color})`}>
                {persona.stat}
              </p>
              <p class="mt-1 text-[13px] text-(--color-text-tertiary)">
                {persona.statDetail}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
