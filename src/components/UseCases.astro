---
const personas = [
  {
    title: "Solo Founders",
    subtitle: "& Indie Hackers",
    description:
      "You're the PM, the engineer, and the support team. Customer conversations happen fast and context switches are constant. North Star gives you a structured memory of every conversation so you stop building based on gut feel.",
    color: "--color-warm",
    stat: "Day one value",
    statDetail: "No setup, no team required",
  },
  {
    title: "Product",
    subtitle: "Managers",
    description:
      "Five customer calls a week generates hundreds of data points. Themes get lost in notebooks and spreadsheets. North Star surfaces patterns across conversations — which pain points recur, how sentiment shifts, which commitments were made.",
    color: "--color-accent",
    stat: "Pattern detection",
    statDetail: "Across all conversations",
  },
  {
    title: "Small",
    subtitle: "Teams",
    description:
      "Engineers talk to customers. Designers run usability tests. Everyone has pieces of the picture, but there's no system to assemble them. North Star becomes the shared product compass — the full picture, for everyone.",
    color: "--color-cool",
    stat: "Shared context",
    statDetail: "Aggregate team insights",
  },
];
---

<section id="use-cases" class="grain relative py-28 md:py-40">
  <!-- Subtle top border -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 h-px w-2/3 bg-gradient-to-r from-transparent via-(--color-border) to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="reveal mb-20 max-w-xl">
      <span class="inline-flex items-center gap-2 text-[13px] tracking-widest text-(--color-text-tertiary) uppercase mb-6 block">
        <span class="inline-block h-px w-8 bg-(--color-warm)"></span>
        Built for
      </span>
      <h2 class="font-display text-[clamp(2.5rem,5vw,3.5rem)] leading-[0.95] tracking-tight text-(--color-text)">
        For people who <em class="text-(--color-warm)">build products</em>
      </h2>
    </div>

    <!-- Persona cards — offset grid -->
    <div class="grid gap-6 md:grid-cols-3">
      {
        personas.map((persona, i) => (
          <div
            class="reveal card-gradient group rounded-2xl p-8 transition-all duration-500 hover:bg-(--color-surface-alt)"
            style={`transition-delay: ${i * 0.1}s; ${i === 1 ? 'transform: translateY(2rem)' : ''}`}
          >
            <!-- Title -->
            <div class="mb-6">
              <h3 class="text-2xl font-medium text-(--color-text) leading-tight">
                {persona.title}
              </h3>
              <h3 class="text-2xl font-medium leading-tight" style={`color: var(${persona.color})`}>
                {persona.subtitle}
              </h3>
            </div>

            <!-- Description -->
            <p class="mb-8 text-sm leading-relaxed text-(--color-text-secondary)">
              {persona.description}
            </p>

            <!-- Stat line -->
            <div class="border-t border-(--color-border) pt-5">
              <p class="text-xs font-medium tracking-wide uppercase" style={`color: var(${persona.color})`}>
                {persona.stat}
              </p>
              <p class="mt-1 text-[13px] text-(--color-text-tertiary)">
                {persona.statDetail}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
