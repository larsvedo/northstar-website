---
const personas = [
  {
    title: "Customer",
    subtitle: "Calls",
    description:
      "Five calls a week generates hundreds of data points. Themes get lost across notebooks and tools. North Star surfaces patterns across all your customer conversations: which pain points recur, how sentiment shifts, what customers actually need.",
    color: "--color-warm",
    stat: "Pattern detection",
    statDetail: "Across every customer conversation",
  },
  {
    title: "Engineering",
    subtitle: "Syncs",
    description:
      "Critical product context gets shared in standups, architecture reviews, and sprint planning, then immediately lost. North Star captures technical decisions and connects them to customer needs. When someone asks \"why are we building this?\", the answer is grounded in real conversations.",
    color: "--color-accent",
    stat: "Bridge the gap",
    statDetail: "Customer needs meet technical decisions",
  },
  {
    title: "Team",
    subtitle: "Discussions",
    description:
      "Support debriefs, design reviews, leadership updates. Every conversation feeds the same knowledge base. A pain point from Tuesday's customer call connects to Thursday's engineering decision. One system, full picture.",
    color: "--color-cool",
    stat: "One knowledge base",
    statDetail: "Every conversation, every insight",
  },
];
---

<section id="use-cases" class="grain relative py-28 md:py-40">
  <!-- Subtle top border -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 h-px w-2/3 bg-gradient-to-r from-transparent via-(--color-border) to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="reveal mb-20 max-w-xl">
      <span class="inline-flex items-center gap-2 text-[13px] tracking-widest text-(--color-text-tertiary) uppercase mb-6 block">
        <span class="inline-block h-px w-8 bg-(--color-warm)"></span>
        How PMs use it
      </span>
      <h2 class="font-display text-[clamp(2.5rem,5vw,3.5rem)] leading-[0.95] tracking-tight text-(--color-text)">
        Every conversation is a <em class="text-(--color-warm)">data point</em>
      </h2>
    </div>

    <!-- Persona cards — offset grid -->
    <div class="grid gap-6 md:grid-cols-3">
      {
        personas.map((persona, i) => (
          <div
            class="reveal card-gradient group rounded-2xl p-8 transition-all duration-500 hover:bg-(--color-surface-alt)"
            style={`transition-delay: ${i * 0.1}s; ${i === 1 ? 'transform: translateY(2rem)' : ''}`}
          >
            <!-- Title -->
            <div class="mb-6">
              <h3 class="text-2xl font-medium text-(--color-text) leading-tight">
                {persona.title}
              </h3>
              <h3 class="text-2xl font-medium leading-tight" style={`color: var(${persona.color})`}>
                {persona.subtitle}
              </h3>
            </div>

            <!-- Description -->
            <p class="mb-8 text-sm leading-relaxed text-(--color-text-secondary)">
              {persona.description}
            </p>

            <!-- Stat line -->
            <div class="border-t border-(--color-border) pt-5">
              <p class="text-xs font-medium tracking-wide uppercase" style={`color: var(${persona.color})`}>
                {persona.stat}
              </p>
              <p class="mt-1 text-[13px] text-(--color-text-tertiary)">
                {persona.statDetail}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
