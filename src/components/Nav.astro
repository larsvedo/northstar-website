---
import ThemeToggle from "./ThemeToggle.astro";
---

<nav
  class="fixed top-0 right-0 left-0 z-50 border-b border-(--color-border) bg-(--color-bg)/80 backdrop-blur-lg"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-2 text-lg font-semibold text-(--color-text)">
      <svg class="h-6 w-6 text-(--color-accent)" viewBox="0 0 32 32" fill="currentColor">
        <path d="M16 2 L18.5 12 L28 12 L20 18.5 L23 28 L16 22 L9 28 L12 18.5 L4 12 L13.5 12 Z"
        ></path>
      </svg>
      North Star
    </a>

    <!-- Desktop links -->
    <div class="hidden items-center gap-8 md:flex">
      <a
        href="#features"
        class="text-sm text-(--color-text-secondary) transition-colors hover:text-(--color-text)"
        >Features</a
      >
      <a
        href="#how-it-works"
        class="text-sm text-(--color-text-secondary) transition-colors hover:text-(--color-text)"
        >How It Works</a
      >
      <a
        href="#pricing"
        class="text-sm text-(--color-text-secondary) transition-colors hover:text-(--color-text)"
        >Pricing</a
      >
      <ThemeToggle />
      <a
        href="#download"
        class="rounded-lg bg-(--color-accent) px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-(--color-accent-hover)"
        >Download</a
      >
    </div>

    <!-- Mobile hamburger -->
    <div class="flex items-center gap-2 md:hidden">
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Toggle menu"
        class="rounded-lg p-2 text-(--color-text-secondary) hover:bg-(--color-surface)"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-(--color-border) md:hidden">
    <div class="flex flex-col gap-1 px-6 py-4">
      <a href="#features" class="mobile-link rounded-lg px-3 py-2 text-sm text-(--color-text-secondary) hover:bg-(--color-surface)">Features</a>
      <a href="#how-it-works" class="mobile-link rounded-lg px-3 py-2 text-sm text-(--color-text-secondary) hover:bg-(--color-surface)">How It Works</a>
      <a href="#pricing" class="mobile-link rounded-lg px-3 py-2 text-sm text-(--color-text-secondary) hover:bg-(--color-surface)">Pricing</a>
      <a href="#download" class="mobile-link mt-2 rounded-lg bg-(--color-accent) px-3 py-2 text-center text-sm font-medium text-white hover:bg-(--color-accent-hover)">Download</a>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    btn.addEventListener("click", () => {
      menu.classList.toggle("hidden");
    });
    menu.querySelectorAll(".mobile-link").forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
      });
    });
  })();
</script>
