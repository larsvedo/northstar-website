---
import ThemeToggle from "./ThemeToggle.astro";
---

<nav
  id="main-nav"
  class="fixed top-0 right-0 left-0 z-50 transition-all duration-500"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 lg:px-8">
    <!-- Logo -->
    <a href="#" class="group flex items-center gap-2.5">
      <div class="relative">
        <svg class="h-5 w-5 text-(--color-accent) transition-transform duration-300 group-hover:scale-110" viewBox="0 0 32 32" fill="currentColor">
          <path d="M16 2 L18.5 12 L28 12 L20 18.5 L23 28 L16 22 L9 28 L12 18.5 L4 12 L13.5 12 Z"></path>
        </svg>
        <div class="absolute inset-0 blur-lg bg-(--color-accent) opacity-0 transition-opacity duration-300 group-hover:opacity-30"></div>
      </div>
      <span class="text-sm font-medium tracking-wide text-(--color-text)">North Star</span>
    </a>

    <!-- Desktop links -->
    <div class="hidden items-center gap-8 md:flex">
      <a href="#features" class="nav-link text-[13px] tracking-wide text-(--color-text-secondary) transition-colors duration-300 hover:text-(--color-text)">Features</a>
      <a href="#how-it-works" class="nav-link text-[13px] tracking-wide text-(--color-text-secondary) transition-colors duration-300 hover:text-(--color-text)">How It Works</a>
      <ThemeToggle />
      <a
        href="#early-access"
        class="group relative overflow-hidden rounded-full bg-(--color-accent-solid) px-5 py-2 text-[13px] font-medium text-white transition-all duration-300 hover:bg-(--color-accent-solid-hover) hover:shadow-glow"
      >
        <span class="relative z-10">Early Access</span>
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent translate-x-[-200%] transition-transform duration-700 group-hover:translate-x-[200%]"></div>
      </a>
    </div>

    <!-- Mobile hamburger -->
    <div class="flex items-center gap-3 md:hidden">
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Toggle menu"
        class="relative h-5 w-5 text-(--color-text-secondary)"
      >
        <span id="hamburger-top" class="absolute top-0.5 left-0 h-px w-5 bg-current transition-all duration-300"></span>
        <span id="hamburger-mid" class="absolute top-[9px] left-0 h-px w-5 bg-current transition-all duration-300"></span>
        <span id="hamburger-bot" class="absolute bottom-0.5 left-0 h-px w-3.5 bg-current transition-all duration-300"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden">
    <div class="border-t border-(--color-border) bg-(--color-bg)/95 backdrop-blur-xl px-6 py-6">
      <div class="flex flex-col gap-1">
        <a href="#features" class="mobile-link rounded-lg px-4 py-3 text-sm text-(--color-text-secondary) transition-colors hover:text-(--color-text) hover:bg-(--color-surface)">Features</a>
        <a href="#how-it-works" class="mobile-link rounded-lg px-4 py-3 text-sm text-(--color-text-secondary) transition-colors hover:text-(--color-text) hover:bg-(--color-surface)">How It Works</a>
        <a href="#early-access" class="mobile-link mt-3 rounded-full bg-(--color-accent-solid) px-4 py-3 text-center text-sm font-medium text-white">Early Access</a>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    var btn = document.getElementById("mobile-menu-btn");
    var menu = document.getElementById("mobile-menu");
    var nav = document.getElementById("main-nav");

    btn.addEventListener("click", function () {
      menu.classList.toggle("hidden");
    });

    menu.querySelectorAll(".mobile-link").forEach(function (link) {
      link.addEventListener("click", function () {
        menu.classList.add("hidden");
      });
    });

    // Nav background on scroll
    var scrolled = false;
    window.addEventListener("scroll", function () {
      var isScrolled = window.scrollY > 20;
      if (isScrolled !== scrolled) {
        scrolled = isScrolled;
        if (scrolled) {
          nav.classList.add("glass");
          nav.querySelector("div").classList.remove("py-5");
          nav.querySelector("div").classList.add("py-3");
        } else {
          nav.classList.remove("glass");
          nav.querySelector("div").classList.remove("py-3");
          nav.querySelector("div").classList.add("py-5");
        }
      }
    });
  })();
</script>
